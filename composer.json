
{
  "name": "discord-php-helpers/rfc9420",
  "description": "RFC 9420 MLS PHP implementation",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "MLS\\": "src/MLS/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MLS\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3",
    "laravel/pint": "^1.21",
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
      "cs": "php-cs-fixer fix",
      "cs-unsupported": "php-cs-fixer fix --allow-unsupported-php-version yes",
      "pint": ["./vendor/bin/pint --config ./pint.json"],
      "unit": "phpunit"
  }
}
